# Server Configuration
PORT=8000

# Database Configuration (MySQL)
# If MySQL connection fails, the backend automatically falls back to SQLite (local file database)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=forecast_ai
DB_PORT=3306

# AI Configuration (Gemini API Key)
# Paste your key here to unlock dynamic, contextual AI insights. 
# If left blank, the app will run in offline mode using detailed rule-based analytical generation.
GEMINI_API_KEY=
